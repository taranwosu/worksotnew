# Frontend (Vite) configuration. Copy to .env.local for development.
# All variables prefixed with VITE_ are exposed to client-side code.

# Base URL of the WorkSoy FastAPI backend (no trailing slash).
# Local dev:    http://localhost:8000
# Staging/prod: https://api.worksoy.com
VITE_BACKEND_URL=http://localhost:8000

# Deployment environment label, used by Sentry tagging.
# "development" | "staging" | "production"
VITE_ENVIRONMENT=development

# ---- Error monitoring (optional) ----
# Install @sentry/react in the build pipeline when this is set.
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
