# ---- Database ----
MONGO_URL=mongodb://localhost:27017
DB_NAME=worksoy

# ---- Auth / sessions ----
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-me-with-a-long-random-string

# Emergent OAuth bridge (Google sign-in)
EMERGENT_AUTH_URL=https://auth.emergentagent.com

# ---- Admin seed ----
# If ADMIN_PASSWORD is unset, no admin user is seeded.
# Use a strong unique value; rotate after first login.
ADMIN_EMAIL=admin@worksoy.com
ADMIN_PASSWORD=

# ---- Payments ----
STRIPE_API_KEY=sk_test_replace_me

# ---- Runtime ----
# "development" | "staging" | "production"
ENVIRONMENT=development

# Comma-separated list of allowed browser origins. Required when ENVIRONMENT
# is not "development". Example for prod:
#   CORS_ORIGINS=https://app.worksoy.com,https://www.worksoy.com
CORS_ORIGINS=

# Auth rate limit: max failed attempts per IP per window (defaults shown)
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=900

# Optional: override uploads directory
# UPLOADS_DIR=/app/backend/uploads

# ---- Transactional email ----
# Choose ONE provider. If neither is set, the mailer logs the intended
# message and the app continues to work — useful for development.
#
# SendGrid (preferred): create an API key with "Mail Send" scope.
SENDGRID_API_KEY=
#
# Generic SMTP fallback (e.g. Mailgun SMTP, Amazon SES SMTP, Postmark).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_USE_TLS=true
#
# From-address shown on outgoing mail. Required for either provider.
EMAIL_FROM=hello@worksoy.com
EMAIL_FROM_NAME=WorkSoy

# ---- App URLs (used in email links) ----
# Public frontend URL — no trailing slash.
APP_BASE_URL=https://worksoy.com
# Password reset link expiry, minutes.
PASSWORD_RESET_TTL_MINUTES=60

# ---- Error monitoring (optional) ----
# When set, the backend will attempt to initialise sentry-sdk on startup.
# Install `sentry-sdk[fastapi]` in the deployment image to enable.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
